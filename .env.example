# Use the Supabase Postgres connection string for LunardoStudio.
# Session pooler works on IPv4 networks and is good for local migrations/seeding:
DATABASE_URL="postgresql://postgres.fesfqntbkwplidbkrgwr:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"
# For Vercel/serverless runtime you may use the transaction pooler from Supabase Connect:
# DATABASE_URL="postgresql://postgres.fesfqntbkwplidbkrgwr:[YOUR-SUPABASE-DB-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?sslmode=require"

AUTH_SECRET="generate-a-long-random-secret"
